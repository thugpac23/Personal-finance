# ── Clerk (auth) ──────────────────────────────────────────────────────────────
# Get these from clerk.com → Your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (match your auth page paths)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Neon (database) ───────────────────────────────────────────────────────────
# Get from neon.tech → Project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.netlify.app

# ── Worker secret ─────────────────────────────────────────────────────────────
# Random string — must be identical in Netlify + Render env vars
WORKER_SECRET=change-me-to-a-random-secret

# ── Optional ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
